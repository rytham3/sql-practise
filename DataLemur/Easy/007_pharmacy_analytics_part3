Solution 1:
SELECT manufacturer,  
       CONCAT('$', ROUND(SUM(total_sales)/1000000), ' million') AS sales_mill
FROM pharmacy_sales
GROUP BY manufacturer
ORDER BY SUM(total_sales) DESC, manufacturer; 


Solution 2:
WITH drug_sales AS (
    SELECT 
        manufacturer,
        SUM(total_sales) AS sales
    FROM pharmacy_sales
    GROUP BY manufacturer
)

SELECT 
    manufacturer,
    ('$' || ROUND(sales/1000000) || ' million') AS sales_mill
FROM drug_sales
ORDER BY sales DESC, manufacturer;
